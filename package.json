{
  "name": "qishu",
  "version": "1.2.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build --webpack && node scripts/prepare-standalone.js",
    "start": "node .next/standalone/server.js",
    "init": "node scripts/init.js",
    "reseed": "node scripts/reseed-cards.js",
    "dev-seed": "node scripts/dev-seed.js",
    "create-temp-admin": "node scripts/create-temp-admin.js",
    "generate:jwt-secret": "node -e \"console.log(require('node:crypto').randomBytes(48).toString('base64url'))\"",
    "postinstall": "node scripts/init.js",
    "lint": "eslint . --ext .js,.mjs",
    "test": "node --test tests/*.test.js",
    "load-test": "node scripts/load-test.js",
    "check": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "eslint-config-next": "16.2.4"
  },
  "overrides": {
    "uuid": "^11.1.0",
    "svix": {
      "uuid": "$uuid"
    }
  }
}