# 栖枢 Profile —— 环境变量样板
# ---------------------------------------------------------------------------
# 注意:
#   • JWT_SECRET 现在只允许保存在服务器环境变量 / .env 中,不会迁入数据库
#   • 其他平台配置仍会在首次启动时 seed 到 settings 表,之后优先使用数据库值
#   • 运行时调优项(NODE_OPTIONS / RATE_LIMIT_MAX_BUCKETS)只在启动时读一次,
#     改完必须重启 pm2 / systemd
# ---------------------------------------------------------------------------

# ── 运行模式(必填) ──────────────────────────────────────────────
NODE_ENV=production

# ── 应用(建议填) ───────────────────────────────────────────────
SITE_NAME=栖枢
# 用于邮件正文内的绝对链接、OAuth 文案等。务必填你实际部署用的域名(Cloudflare
# 接入的那个),不要带结尾斜杠。
SITE_URL=https://your-domain.com

# ── 认证(必填) ─────────────────────────────────────────────────
# 推荐: npm run generate:jwt-secret
# 生产环境要求至少 64 字符,且不再允许从后台查看或修改
JWT_SECRET=

# 首次启动时创建管理员使用的邮箱 + 密码。缺一则 scripts/init.js 会跳过管理员创建。
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── 邮件(生产环境必填) ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@your-domain.com

# ── OAuth 静态客户端秘钥 ─────────────────────────────────────────
# 每个在 config/oauth-clients.js 里声明了 secretEnv 的客户端都要在这里
# 配对应的 secret。首次启动迁入 settings 表后,之后轮换直接改 /admin/settings。
QISHU_DEFAULT_CLIENT_SECRET=

# ── Cloudflare Turnstile(推荐) ──────────────────────────────────
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ── 数据目录(可选) ─────────────────────────────────────────────
# QISHU_DATA_DIR=./data

# ── 限流桶总量上限(内存保护) ──────────────────────────────────
# 1.2.0 默认从 5000 下调到 2000;如果确实有高并发合法用户,再往上调。
# RATE_LIMIT_MAX_BUCKETS=2000

# ── 运行时内存(推荐,pm2 已帮你处理) ────────────────────────────
# 如果用 systemd 或手动 `npm start`,想控住内存,可在 shell / unit 里设置:
#   NODE_OPTIONS=--max-old-space-size=160
# pm2 模式下由 ecosystem.config.cjs 内的 node_args 传入,不要在这里重复设。
#
# ⚠️ 现实提醒:Next.js + React 19 + better-sqlite3 的组合最低 RSS 就是
#    120–180MB(idle),50 并发峰值 200–350MB 属正常。无法通过仅调这一个值
#    压到 100MB 以下 —— 要更低必须换框架。见 DEPLOY.md 第 3 节说明。
# NODE_OPTIONS=
