# 栖枢 Profile —— 环境变量样板
# ---------------------------------------------------------------------------
# 注意:
#   • JWT_SECRET 现在只允许保存在服务器环境变量 / .env 中,不会迁入数据库
#   • 其他平台配置仍会在首次启动时 seed 到 settings 表,之后优先使用数据库值
# ---------------------------------------------------------------------------

# ── 运行模式(必填) ──────────────────────────────────────────────
NODE_ENV=production

# ── 应用(建议填) ───────────────────────────────────────────────
SITE_NAME=栖枢
SITE_URL=https://your-domain.com

# ── 认证(必填) ─────────────────────────────────────────────────
# 推荐: npm run generate:jwt-secret
# 生产环境要求至少 64 字符,且不再允许从后台查看或修改
JWT_SECRET=

# 首次启动时创建管理员使用的邮箱 + 密码。缺一则 scripts/init.js 会跳过管理员创建。
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── 邮件(生产环境必填) ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@your-domain.com

# ── OAuth 静态客户端秘钥 ─────────────────────────────────────────
# 每个在 config/oauth-clients.js 里声明了 secretEnv 的客户端都要在这里
# 配对应的 secret。首次启动迁入 settings 表后,之后轮换直接改 /admin/settings。
QISHU_DEFAULT_CLIENT_SECRET=

# ── Cloudflare Turnstile(推荐) ──────────────────────────────────
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ── 数据目录(可选) ─────────────────────────────────────────────
# QISHU_DATA_DIR=./data

# ── 可选:限流桶总量上限(内存保护) ───────────────────────────────
# RATE_LIMIT_MAX_BUCKETS=5000
