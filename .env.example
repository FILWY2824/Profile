# ───────────────────────────────────────────────────────────────────────────
# 栖枢 Profile — 环境变量示例
# 第一次启动时读入 data/app.db 的 settings 表;之后改配置一律走后台,
# 此文件的修改不会被重新读入(避免部署方式漂移)。
# ───────────────────────────────────────────────────────────────────────────

# 监听地址。容器内一律 0.0.0.0:8080,对外映射由 docker-compose 管。
LISTEN_ADDR=0.0.0.0:8080

# 站点对外 URL,用于邮件里的链接与 OAuth redirect 白名单校验。
SITE_URL=http://localhost:8080

# ── 安全密钥(生产必填) ────────────────────────────────────────────────
# 生成方法:openssl rand -base64 48  或  head -c 48 /dev/urandom | base64
# 长度硬性要求:≥ 32 字节。启动时校验不通过会立即 panic。
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes-long-please

# ── 初始管理员(仅首次建库有效) ───────────────────────────────────────
# 两者都填了,init 才会建管理员账号;否则只建空库,事后跑 create_admin 脚本。
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── 邮件服务(Resend)──────────────────────────────────────────────────
# 未填时进入开发模式:验证码会在 HTTP 响应里直接回显,不发邮件。
# 生产必须填。
RESEND_API_KEY=
RESEND_FROM=

# ── 运行时(可选)──────────────────────────────────────────────────────
# 生产建议设置 production,cookie 的 Secure 标志依赖它。
APP_ENV=production

# Go 运行时内存软上限,帮助 GC 在小内存 VPS 上更激进。
GOMEMLIMIT=80MiB
GOGC=50

# 数据目录(默认 ./data)
DATA_DIR=/data

# CORS 允许的来源(逗号分隔),用于未来手机 App / 第三方前端。
# 留空 = 只允许同源。
ALLOWED_ORIGINS=

# ── Cloudflare Turnstile(可选) ──────────────────────────────────────
# 后台 /admin/settings 也能改,这里只是首次 seed。
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
