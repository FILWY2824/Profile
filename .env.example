# App
APP_NAME=Alma Portal
APP_VERSION=1.0.0
NODE_ENV=development

# Server
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=false
MAX_BODY_BYTES=65536
STATIC_ASSET_MAX_AGE_SECONDS=300

# Session / Security
SESSION_COOKIE_NAME=alma_session
SESSION_MAX_AGE_MS=604800000
SECURE_COOKIES=false
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Auth
VERIFICATION_TTL_MS=600000
VERIFICATION_CODE_LENGTH=6
MAX_VERIFICATION_ATTEMPTS=5
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=64
MAX_SESSIONS_PER_USER=20

# Rate limiting
RATE_LIMIT_LOGIN_WINDOW_MS=600000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_VERIFY_REQUEST_WINDOW_MS=600000
RATE_LIMIT_VERIFY_REQUEST_MAX=8
RATE_LIMIT_VERIFY_CHECK_WINDOW_MS=600000
RATE_LIMIT_VERIFY_CHECK_MAX=20
RATE_LIMIT_ADMIN_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=60

# Default admin seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_EMAIL=admin@teamcy.eu.cc
ADMIN_DISPLAY_NAME=系统管理员

# Mail / Resend
MAIL_FROM=admin@teamcy.eu.cc
MAIL_REPLY_TO=admin@teamcy.eu.cc
RESEND_API_KEY=
MAIL_DEV_LOG_CODES=true
