# 栖枢 Profile —— 环境变量样板
# ---------------------------------------------------------------------------
# 本文件只在**首次启动**(scripts/init.js)时被读取并 seed 到 settings 表。
# 首次启动之后,所有配置的权威来源是 /admin/settings,改 .env 不会生效。
# 换句话说:
#   • 首次部署前 → 把下面这几项填好
#   • 首次启动后 → 后台 /admin/settings 修改,.env 可以放着不动或者删掉
# ---------------------------------------------------------------------------

# ── 运行模式(必填) ──────────────────────────────────────────────
# 生产部署必须设成 production,否则 JWT 会走弱的开发默认值 + cookie 不带 Secure
NODE_ENV=production

# ── 应用(建议填) ───────────────────────────────────────────────
SITE_NAME=栖枢
SITE_URL=https://your-domain.com

# ── 认证(必填) ─────────────────────────────────────────────────
# 生成强随机:node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# 必须 ≥ 32 字符
JWT_SECRET=

# 首次启动时创建管理员使用的邮箱 + 密码。缺一则 scripts/init.js 会跳过管理员创建。
# 登录一次后,这两个值就不再被用到;到 /admin/users 修改或创建新管理员。
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── 邮件(生产环境必填) ──────────────────────────────────────────
# Resend API Key(re_ 开头)与发件人地址。
# 生产环境下若 RESEND_API_KEY 为空,所有涉及邮件的流程会直接 500 而不是
# 静默"假成功",所以这两个在上线前务必填好。
# 开发环境下若为空,验证码会打到 stdout(pm2 logs 能看到),方便本地调试。
RESEND_API_KEY=
RESEND_FROM=noreply@your-domain.com

# ── OAuth 静态客户端秘钥 ─────────────────────────────────────────
# 每个在 config/oauth-clients.js 里声明了 secretEnv 的客户端都要在这里
# 配对应的 secret。首次启动迁入 settings 表后,之后轮换直接改 /admin/settings。
# 最低长度 16(由 lib/settingsValidation 校验)。
QISHU_DEFAULT_CLIENT_SECRET=

# ── Cloudflare Turnstile(推荐) ──────────────────────────────────
# 登录 / 注册 / 忘记密码 的机器人挑战。没配之前 TURNSTILE_ENABLED=1 也
# 会自动 no-op,不会卡住登录。
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ── 数据库备份 SFTP(可选) ──────────────────────────────────────
# 启用后 /admin/backup 可以一键把 SQLite 打包上传到远端。这些值也都能在
# 后台改,.env 只是首次启动的 seed。
# BACKUP_ENABLED=0
# BACKUP_HOST=
# BACKUP_PORT=22
# BACKUP_USER=
# BACKUP_AUTH_METHOD=password      # 或 key
# BACKUP_PASSWORD=
# BACKUP_PRIVATE_KEY=              # PEM 多行文本;.env 里支持多行需要用引号包起来
# BACKUP_PRIVATE_KEY_PASSPHRASE=
# BACKUP_REMOTE_DIR=/var/backups/qishu

# ── 数据目录(可选) ─────────────────────────────────────────────
# 默认 ./data。测试 / 多实例隔离时可以指向其他位置。一般不用改。
# QISHU_DATA_DIR=./data
