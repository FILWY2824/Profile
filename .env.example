# ───────────────────────────────────────────────────────────────────────────
# 栖枢 Profile — 环境变量样板
# 复制为 .env 后再编辑:`cp .env.example .env`
# ───────────────────────────────────────────────────────────────────────────

# ── 监听 / 部署 ───────────────────────────────────────────────────────────
LISTEN_ADDR=0.0.0.0:8080
APP_ENV=production
SITE_URL=http://localhost:3000
DATA_DIR=/data

ALLOWED_ORIGINS=

# ── 安全 [必填] ──────────────────────────────────────────────────────────
# 至少 32 字符。生成:openssl rand -base64 48
JWT_SECRET=

# 是否信任前置代理上送的 X-Forwarded-For / X-Real-IP / CF-Connecting-IP
# 直接对外暴露设 0;部署在 Cloudflare/Nginx/Caddy 反代后面设 1。
TRUST_PROXY=0

# ── 首次启动管理员 ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeNow123!

# ── 邮件(运行期可在管理后台修改) ─────────────────────────────────────────
# 留空则进入 DEV 模式:验证码打印到容器日志。
# 生产环境务必填上 Resend Key,APP_ENV=production 时不会把验证码回显前端。
RESEND_API_KEY=
RESEND_FROM=

# ── Cloudflare Turnstile(运行期可在管理后台修改) ──────────────────────────
TURNSTILE_ENABLED=0
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── 代理 ──────────────────────────────────────────────────────────────────
# 用于 docker build 与运行期出站。NO_PROXY 必须至少包含 localhost。
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1

# Go 模块代理 / npm 镜像。中国大陆环境推荐:
# GOPROXY=https://goproxy.cn,direct
# NPM_REGISTRY=https://registry.npmmirror.com
GOPROXY=https://proxy.golang.org,direct
NPM_REGISTRY=
