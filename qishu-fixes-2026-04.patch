+const SHANGHAI_FMT_FULL = new Intl.DateTimeFormat("zh-CN", {
+  timeZone: SHANGHAI_TZ,
+  year: "numeric",
+  month: "2-digit",
+  day: "2-digit",
+  hour: "2-digit",
+  minute: "2-digit",
+  second: "2-digit",
