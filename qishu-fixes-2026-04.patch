+// 把 Intl.DateTimeFormat 的输出再清理一次。zh-CN 默认会输出
+// "2026/04/26 14:32:01",我们改成 "2026-04-26 14:32:01" 与日志/SQL 习惯一致。
+function normalizeFull(s) {
+  return s.replace(/\//g, "-");
+}
+function normalizeDate(s) {
+  return s.replace(/\//g, "-");
